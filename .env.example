# Copy to .env and adjust as needed: cp .env.example .env

# PostgreSQL (used by postgres service + DATABASE_URL for api)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=urlshortener

# Host ports (optional overrides)
POSTGRES_PORT=5432
REDIS_PORT=6379
ADMINER_PORT=8080
API_PORT=3000

# API bind (inside container)
API_HOST=0.0.0.0

# Connection strings for the api service (Compose DNS: postgres, redis)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/urlshortener
REDIS_URL=redis://redis:6379
